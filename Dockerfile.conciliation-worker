FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /conciliation-worker ./cmd/conciliation-worker

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /conciliation-worker /conciliation-worker
ENTRYPOINT ["/conciliation-worker"]
